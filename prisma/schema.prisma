generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  location  String
  sports    String?
  features  String?
  feedback  String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email])
}
