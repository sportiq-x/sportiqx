generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String   @unique
  location  String
  sports    String?
  features  String?
  feedback  String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
